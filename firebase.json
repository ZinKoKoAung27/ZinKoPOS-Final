                    batch.set(newSaleRef, newSaleData);

                    await batch.commit();
                    
                    setLastSale({ id: newSaleRef.id, ...newSaleData } as Sale);
                    setIsReceiptOpen(true);
                    
                    setIsDebtPaymentOpen(false);
                    setSelectedCustomerForDebt(null);
